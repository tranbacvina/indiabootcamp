<script>
    const modalCheckCourse = new tingle.modal({
        footer: true,
        stickyFooter: true
    })

    modalCheckCourse.addFooterBtn('Checkout', 'button -md -purple-1 text-white tingle-btn--pull-left', async function () {
        const items = []
        const courseItemClass = [...document.getElementsByClassName("course-item")]
        const courseItemBuy = courseItemClass.forEach(item => items.push({ courseID: item.getAttribute("courseID") }))
        const email = document.getElementById("email").value

        try {
            const createOrder = await axios.post('/order/createvnapi', {
                email, items
            })
            console.log(createOrder.data)
            const itemsForGtag = createOrder.data.order.orderItems.map(item => {
                return {
                    item_id: item.course.id,
                    item_name: item.course.name,
                    price: item.course.price,
                    quantity: 1
                }
            })
            console.log(itemsForGtag)
            gtag("event", "purchase", {
                transaction_id: createOrder.data.order.uuid,
                value: createOrder.data.order.priceus,
                currency: "USD",
                items: itemsForGtag
            });
            fbq('track', 'Purchase', { currency: "USD", value: createOrder.data.order.priceus });
            window.location.href = `/order/${createOrder.data.order.uuid}`
        } catch (error) {
            alert(error)
        }

    });
    // modalCheckCourse.addFooterBtn('Huỷ', 'button -md -purple-3 text-purple-1 tingle-btn--pull-right', function () {
    //     modalCheckCourse.close();
    // });
    const handle_checkcourse = document.getElementById("handle_checkcourse");
    handle_checkcourse.addEventListener("submit", async (event) => {
        try {
            event.preventDefault()
            const uri = document.getElementById("links").value
            const email = document.getElementById("email").value

            let links = Array.from(uri.match(/[(http(s)?):\/\/(www\.)?a-zA-Z0-9@:%._\+~#=]{2,256}\.[a-z]{2,6}\b([-a-zA-Z0-9@:%_\+.~#?&//=]*)/ig))
            links = links.map(item => { return { uri: item, topicId: null } })

            modalCheckCourse.open()
            modalCheckCourse.setContent('Fetching data, please wait...');
            const checkCourseRequest = await axios.post('/course/check', {
                email, links
            })
            var codeHtml = ``
            if (checkCourseRequest.data[0].success) {

                for (let course of checkCourseRequest.data) {
                    if (!course.success) {
                        toastr.error(checkCourseRequest.data.messenger)
                        continue
                    }

                    const childHTML = `<div class="border-bottom-light course-item" courseID="${course.data.id}">
              <div  class="coursesCard -type-1 row y-gap-20 flex-row items-center">
                <div class="col-2 my-2">
                  <div class="coursesCard__image rounded-8 relative">
                    <img class="w-1/1 rounded-8" src="${course.data.image}" alt="image">
                    <div class="coursesCard__image_overlay rounded-8"></div>
                  </div>
                </div>

                <div class="col-8">
                  <div class="text-17 lh-15 fw-500 text-dark-1 mt-10">${course.data.name}</div>
                </div>
                
                <div class="col-2">
                  <div class="text-right md:text-left">
                    <div class="text-17 lh-1 fw-500 text-dark-1 mt-10">${(course.data.priceus / 100).toLocaleString('en-US', {
                        maximumFractionDigits: 2,
                        style: 'currency',
                        currency: 'USD'
                    })}</div>
                  </div>
                </div>
              </div>
            </div>`
                    codeHtml += childHTML
                }

                modalCheckCourse.setContent(codeHtml);
            } else {
                toastr.error(checkCourseRequest.data.messenger)
            }
        } catch (error) {
            toastr.error('Something is wrong, please check again or contact the administrator')
        }


    })
</script>

